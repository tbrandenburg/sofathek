# Sofathek Backend .dockerignore
# Optimizes Docker build context by excluding unnecessary files

# Node.js dependency and cache directories
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnp.*
.yarn/

# Build and development artifacts
dist/
coverage/
*.tsbuildinfo
.nyc_output
.cache
.parcel-cache

# Test artifacts and reports
test-results/
playwright-report/
__tests__/
*.test.ts
*.test.js
*.spec.ts
*.spec.js
src/test-*
src/__tests__/

# Logs and runtime data
logs/
*.log
pids
*.pid
*.seed
*.pid.lock

# Development and temp files
temp/
.temp
*.tmp
*.swp
*.swo
*~

# IDE and editor files
.vscode/
.idea/
*.sublime-*
.DS_Store
Thumbs.db

# Environment and config files
.env
.env.*
!.env.example

# Version control
.git/
.gitignore
.gitattributes

# Documentation and project files
README.md
CHANGELOG.md
LICENSE
*.md

# CI/CD and development tools
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
azure-pipelines.yml
.dockerignore
docker-compose*.yml
Dockerfile*

# Backup and temporary files
*.backup
*.bak
*.orig

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Development scripts and testing utilities
scripts/
dev/
.claude/

# Static analysis and linting cache
.eslintcache
.stylelintcache

# Package manager files that aren't needed in build
# package-lock.json  # Keep for reproducible builds
yarn.lock
.yarnrc
.npmrc

# Optional: Exclude source maps in production builds
# *.map

# Keep only essential files for production build:
# - package.json (for dependencies)
# - src/ (source code)
# - tsconfig.json (TypeScript config)
# Other files are copied via COPY . . but ignored by this file