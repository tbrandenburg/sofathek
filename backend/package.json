{
  "name": "sofathek-backend",
  "version": "0.1.0",
  "description": "Backend API server for Sofathek family media center",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:youtube": "ts-node src/test-youtube-integration.ts",
    "test:queue": "ts-node src/test-download-queue.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "winston": "^3.8.2",
    "dotenv": "^16.0.3",
    "youtube-dl-exec": "^3.1.3",
    "ffmpeggy": "^2.1.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^18.15.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/jest": "^29.5.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.38.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "backend",
    "api",
    "video-streaming",
    "media-server"
  ],
  "author": "Thomas Brandenburg",
  "license": "MIT"
}