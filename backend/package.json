{
  "name": "sofathek-backend",
  "version": "0.1.0",
  "description": "Backend API server for Sofathek family media center",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest src/__tests__/unit",
    "test:integration": "jest src/__tests__/integration",
    "test:real-youtube": "RUN_REAL_DOWNLOAD_TESTS=true jest src/__tests__/integration/routes/youtube.integration.test.ts",
    "test:youtube": "ts-node scripts/youtube-integration.ts",
    "test:queue": "ts-node scripts/download-queue.ts",
    "postinstall": "node -e \"require('youtube-dl-exec/scripts/postinstall.js')\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.3.0",
    "ffmpeggy": "^2.1.0",
    "ffprobe-static": "^3.1.0",
    "logform": "^2.7.0",
    "readable-stream": "^3.6.2",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "youtube-dl-exec": "^3.1.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@humanwhocodes/config-array": "^0.13.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.0",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-runtime": "^29.7.0",
    "jest-util": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "handlebars": ">=4.7.9",
    "path-to-regexp": ">=0.1.13 <1.0.0"
  },
  "keywords": [
    "backend",
    "api",
    "video-streaming",
    "media-server"
  ],
  "author": "Thomas Brandenburg",
  "license": "MIT"
}
