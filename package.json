{
  "name": "sofathek",
  "version": "0.1.0",
  "description": "Self-hosted family media center with Netflix-like interface and YouTube download capabilities",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "docker:dev": "docker-compose up --build",
    "docker:stop": "docker-compose down",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "type-check": "npm run --workspaces --if-present type-check",
    "lint": "npm run --workspaces --if-present lint",
    "test": "npm run --workspaces --if-present test",
    "build": "npm run --workspaces --if-present build"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tbrandenburg/sofathek.git"
  },
  "keywords": [
    "media-center",
    "family-safe",
    "self-hosted",
    "video-streaming",
    "youtube-downloader"
  ],
  "author": "Thomas Brandenburg",
  "license": "MIT"
}