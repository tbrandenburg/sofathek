{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "sequential_thinking": {
      "type": "local",
      "command": ["npx", "-y","@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    }
  },
  "permission": {
    "read": "allow",
    "write": "allow",
    "edit": "allow",
    "bash": "allow",
    "skill": "allow",
    "question": "deny",
    "doom_loop": "deny",
    "external_directory": "deny",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "patch": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "webfetch": "allow"
  }
}